{
  "name": "taronote",
  "version": "1.0.0",
  "description": "A floating macOS Note app for saving reusable phrases.",
  "author": "Taro",
  "main": "out/main/index.js",
  "type": "module",
  "scripts": {
    "dev": "electron-vite dev",
    "start": "electron-vite dev",
    "typecheck": "tsc -p tsconfig.node.json --noEmit && tsc -p tsconfig.web.json --noEmit",
    "build": "npm run typecheck && electron-vite build",
    "preview": "electron-vite preview",
    "app:pack": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder"
  },
  "dependencies": {
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "less": "^4.6.4",
    "typescript": "^5.7.2",
    "vite": "^5.4.11"
  },
    "build": {
      "appId": "com.taro.taronote",
      "productName": "TaroNote",
      "copyright": "Copyright © 2026 Taro",
      "artifactName": "${productName}-${version}-${arch}.${ext}",
      "files": [
        "out/**/*"
      ],
      "mac": {
        "category": "public.app-category.productivity",
        "icon": "assets/app-icons/taronote.icns",
        "target": [
          "dmg",
          "zip"
        ]
      },
    "directories": {
      "output": "release"
    }
  }
}
